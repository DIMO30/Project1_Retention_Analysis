{
	"name": "d_PL_Bronze_PeerInsights_Ingest",
	"properties": {
		"description": "Purpose: landing/peer_insights/ se JSON file uthao → bronze/peer_insights/ mein Parquet mein copy karo",
		"activities": [
			{
				"name": "DimoCopy_PeerInsights_To_Bronze",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "JsonSource",
						"storeSettings": {
							"type": "AzureBlobFSReadSettings",
							"recursive": true,
							"enablePartitionDiscovery": false
						},
						"formatSettings": {
							"type": "JsonReadSettings"
						}
					},
					"sink": {
						"type": "ParquetSink",
						"storeSettings": {
							"type": "AzureBlobFSWriteSettings"
						},
						"formatSettings": {
							"type": "ParquetWriteSettings"
						}
					},
					"enableStaging": false,
					"enableSkipIncompatibleRow": true
				},
				"inputs": [
					{
						"referenceName": "dDS_Landing_PeerInsights_JSON",
						"type": "DatasetReference"
					}
				],
				"outputs": [
					{
						"referenceName": "dDS_Bronze_PeerInsights_Delta",
						"type": "DatasetReference"
					}
				]
			}
		],
		"folder": {
			"name": "Child Pipelines"
		},
		"annotations": []
	}
}